<Window x:Class="FinanceFlow.Wpf.Views.AddTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Transaction" Height="350" Width="400"
        WindowStartupLocation="CenterOwner" Background="#F5F5F7">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="New Transaction" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Amount (€)" Margin="0,0,0,5"/>
            <TextBox x:Name="txtAmount" Margin="0,0,0,15" Padding="8" FontSize="16"/>

            <TextBlock Text="Description" Margin="0,0,0,5"/>
            <TextBox x:Name="txtDescription" Margin="0,0,0,20" Padding="8" FontSize="16"/>

            <Button Content="Save Transaction" 
                    Click="BtnSave_Click" 
                    Background="#27AE60" Foreground="White" 
                    Padding="10" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>