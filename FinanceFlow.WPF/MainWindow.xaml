<Window x:Class="FinanceFlow.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FinanceFlow" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="10">
                <TextBlock Text="FinanceFlow" Foreground="White" FontSize="24" FontWeight="Bold" Margin="10,20,10,40" HorizontalAlignment="Center"/>

                <Button x:Name="BtnDashboard" Content="Dashboard" Style="{StaticResource MenuButtonStyle}" Click="BtnDashboard_Click"/>
                <Button x:Name="BtnTransactions" Content="Transactions" Style="{StaticResource MenuButtonStyle}" Click="BtnTransactions_Click"/>
                <Button x:Name="BtnCategories" Content="Categories" Style="{StaticResource MenuButtonStyle}" Click="BtnCategories_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Finances" FontSize="28" FontWeight="SemiBold" Foreground="#333"/>

            <Border Grid.Row="1" Background="White" CornerRadius="15" Margin="0,20,0,0" Padding="20" VerticalAlignment="Top" Height="150">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Balance" Foreground="#7F8C8D" FontSize="16"/>
                    <TextBlock x:Name="txtTotalBalance" Text="0.00 €" Foreground="#27AE60" FontSize="42" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Button Grid.Row="2" 
                    Content="+ Add Transaction" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top"
                    Margin="0,30,0,30"
                    Padding="20,10"
                    Background="#27AE60" 
                    Foreground="White" 
                    FontSize="16" 
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="BtnAddTransaction_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#27AE60"/>
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Style.Resources>
                    </Style>
                </Button.Style>
            </Button>

            <DataGrid Grid.Row="3" x:Name="dgTransactions" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      Background="Transparent" 
                      BorderThickness="0"
                      GridLinesVisibility="None"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="150"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2} €}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

        </Grid>
    </Grid>
</Window>